{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/experiment_manifest.schema.json",
  "title": "Experiment Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_name",
    "title",
    "date",
    "author",
    "task",
    "status",
    "dataset",
    "model",
    "config",
    "code",
    "evaluation",
    "assets",
    "tags"
  ],
  "properties": {
    "run_name": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}_[a-z0-9]+_[a-z0-9]+_[a-z0-9]+_[a-z0-9]+(?:_[a-z0-9]+)?$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "subtype"
      ],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "subtype": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "verdict",
        "publish"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "draft",
            "running",
            "completed",
            "failed",
            "archived"
          ]
        },
        "verdict": {
          "type": "string",
          "enum": [
            "keep",
            "reject",
            "inconclusive",
            "baseline",
            "milestone"
          ]
        },
        "publish": {
          "type": "boolean"
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "split",
        "source_type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "split": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "base_checkpoint",
        "adaptation",
        "preset"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "base_checkpoint": {
          "type": "string",
          "minLength": 1
        },
        "adaptation": {
          "type": "string",
          "minLength": 1
        },
        "preset": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "overrides"
      ],
      "properties": {
        "seed": {
          "type": "integer"
        },
        "overrides": {
          "type": "object"
        }
      }
    },
    "code": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "repo"
      ],
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "repo": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_metric",
        "metrics_file"
      ],
      "properties": {
        "primary_metric": {
          "type": "string",
          "minLength": 1
        },
        "metrics_file": {
          "type": "string",
          "const": "metrics.json"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "representative_count",
        "failure_count",
        "qc_count"
      ],
      "properties": {
        "representative_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "qc_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
